{
    "name": "tracegraph/sample-laravel-api",
    "description": "TraceGraph sample — Laravel REST API with product catalogue and order management",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "tracegraph/laravel": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "test:trace": "TRACEGRAPH_ENABLED=0 phpunit --testdox"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/trace-laravel",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
