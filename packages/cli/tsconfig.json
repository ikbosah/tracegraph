{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "paths": {
      "@tracegraph/ai-coverage":      ["../ai-coverage/src/index.ts"],
      "@tracegraph/shared-types":    ["../shared-types/src/index.ts"],
      "@tracegraph/trace-core":      ["../trace-core/src/index.ts"],
      "@tracegraph/trace-js":        ["../trace-js/src/index.ts"],
      "@tracegraph/trace-js/*":      ["../trace-js/src/*"],
      "@tracegraph/trace-sanitizer": ["../trace-sanitizer/src/index.ts"],
      "@tracegraph/graph-engine":    ["../graph-engine/src/index.ts"],
      "@tracegraph/ci-reporter":      ["../ci-reporter/src/index.ts"],
      "@tracegraph/scenario-runner":  ["../scenario-runner/src/index.ts"],
      "@tracegraph/vitest":           ["../trace-vitest/src/index.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "bin/**/*"]
}
