{
  "name": "@tracegraph/jest",
  "version": "0.1.3",
  "description": "TraceGraph reporter for Jest — captures test structure and results as structured traces",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external jest --external '@jest/*'",
    "typecheck": "tsc --noEmit",
    "test": "jest --testPathPattern tests/"
  },
  "dependencies": {
    "@tracegraph/shared-types": "workspace:*",
    "@tracegraph/trace-core": "workspace:*"
  },
  "peerDependencies": {
    "jest": ">=27.0.0"
  },
  "devDependencies": {
    "@jest/reporters": "^29.0.0",
    "@jest/test-result": "^29.0.0",
    "@jest/types": "^29.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}
