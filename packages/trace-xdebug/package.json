{
  "name": "@tracegraph/trace-xdebug",
  "version": "0.0.1",
  "private": true,
  "description": "Streaming Xdebug .xt trace file parser — converts Xdebug function call logs into TraceEvent streams",
  "main": "dist/index.cjs",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.cjs",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=cjs --platform=node --outfile=dist/index.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tracegraph/shared-types": "workspace:*",
    "@tracegraph/trace-core":   "workspace:*"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
