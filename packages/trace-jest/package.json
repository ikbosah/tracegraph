{
  "name": "@tracegraph/jest",
  "version": "0.0.1",
  "private": true,
  "description": "TraceGraph reporter for Jest — captures test structure and results as structured traces",
  "main": "dist/index.cjs",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.cjs",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=cjs --platform=node --external:@jest/reporters --external:@jest/test-result --external:@jest/types --outfile=dist/index.cjs",
    "typecheck": "tsc --noEmit",
    "test": "jest --testPathPattern tests/"
  },
  "dependencies": {
    "@tracegraph/shared-types": "workspace:*",
    "@tracegraph/trace-core": "workspace:*"
  },
  "peerDependencies": {
    "jest": ">=27.0.0"
  },
  "devDependencies": {
    "@jest/reporters": "^29.0.0",
    "@jest/test-result": "^29.0.0",
    "@jest/types": "^29.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}
