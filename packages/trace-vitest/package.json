{
  "name": "@tracegraph/vitest",
  "version": "0.1.0",
  "description": "TraceGraph reporter for Vitest — captures test structure and results as structured traces",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs",
      "types":   "./dist/index.d.ts"
    },
    "./reporter": {
      "import":  "./dist/reporter.js",
      "require": "./dist/reporter.cjs",
      "types":   "./dist/reporter.d.ts"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build":     "tsup src/index.ts src/reporter.ts --format cjs,esm --dts --external vitest --external '@tracegraph/*'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tracegraph/shared-types": "workspace:*",
    "@tracegraph/trace-core":   "workspace:*"
  },
  "peerDependencies": {
    "@tracegraph/trace-js": "workspace:*",
    "vitest":               ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@tracegraph/trace-js": { "optional": true }
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
