{
  "name": "@tracegraph/trace-js",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript instrumentation adapters for TraceGraph",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./register": {
      "types":   "./dist/register.d.ts",
      "import":  "./dist/register.js",
      "require": "./dist/register.cjs"
    },
    "./register-cjs": {
      "types":   "./dist/register-cjs.d.ts",
      "import":  "./dist/register-cjs.js",
      "require": "./dist/register-cjs.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build":     "tsup src/index.ts src/register.ts src/register-cjs.ts --format cjs,esm --dts --external '@tracegraph/*' --external express",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tracegraph/shared-types":    "workspace:*",
    "@tracegraph/trace-core":      "workspace:*",
    "@tracegraph/trace-sanitizer": "workspace:*"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "express":        "^4.18.2"
  }
}
