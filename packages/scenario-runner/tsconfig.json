{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@tracegraph/shared-types":    ["../shared-types/src/index.ts"],
      "@tracegraph/shared-types/*":  ["../shared-types/src/*"],
      "@tracegraph/trace-core":      ["../trace-core/src/index.ts"],
      "@tracegraph/trace-core/*":    ["../trace-core/src/*"]
    }
  },
  "include": ["src/**/*"]
}
