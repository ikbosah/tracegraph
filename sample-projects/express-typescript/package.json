{
  "name": "tracegraph-sample-express",
  "version": "0.0.2",
  "private": true,
  "description": "Sample Express TypeScript API demonstrating TraceGraph M1 onboarding",
  "main": "src/app.ts",
  "scripts": {
    "dev": "tsx src/app.ts",
    "test": "vitest run",
    "trace:test": "tracegraph run -- pnpm run test",
    "trace:report": "tracegraph open --html .tracegraph/reports/latest.report.json"
  },
  "dependencies": {
    "@tracegraph/trace-js": "workspace:*",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
