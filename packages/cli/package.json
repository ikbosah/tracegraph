{
  "name": "@tracegraph/cli",
  "version": "0.3.1",
  "description": "CLI-first runtime assurance platform",
  "main": "dist/index.js",
  "bin": {
    "tracegraph": "bin/tracegraph.js"
  },
  "files": [
    "dist",
    "bin",
    "webview-bundle"
  ],
  "scripts": {
    "build":       "tsup src/index.ts --format cjs --outDir dist",
    "typecheck":   "tsc --noEmit",
    "postinstall": "node ./bin/postinstall.js || true"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tracegraph/ai-coverage": "workspace:*",
    "@tracegraph/ci-reporter": "workspace:*",
    "@tracegraph/graph-engine": "workspace:*",
    "@tracegraph/scenario-runner": "workspace:*",
    "@tracegraph/shared-types": "workspace:*",
    "@tracegraph/static-graph": "workspace:*",
    "@tracegraph/trace-core": "workspace:*",
    "@tracegraph/trace-xdebug": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@tracegraph/trace-js": "workspace:*",
    "@tracegraph/trace-sanitizer": "workspace:*",
    "@tracegraph/vitest": "workspace:*"
  }
}
