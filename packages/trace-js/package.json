{
  "name": "@tracegraph/trace-js",
  "version": "0.0.1",
  "private": true,
  "description": "JavaScript/TypeScript instrumentation adapters for TraceGraph",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".":              "./src/index.ts",
    "./register":     "./src/register.ts",
    "./register-cjs": "./src/register-cjs.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tracegraph/shared-types":    "workspace:*",
    "@tracegraph/trace-core":      "workspace:*",
    "@tracegraph/trace-sanitizer": "workspace:*"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "express": "^4.18.2"
  }
}
