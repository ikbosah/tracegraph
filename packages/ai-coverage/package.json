{
  "name": "@tracegraph/ai-coverage",
  "version": "0.1.4",
  "description": "AI Change Coverage and Prompt Pack Builder for TraceGraph",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external '@tracegraph/*'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tracegraph/shared-types": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
