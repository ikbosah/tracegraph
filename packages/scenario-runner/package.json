{
  "name": "@tracegraph/scenario-runner",
  "version": "0.1.0",
  "description": "Scenario runner and TraceBundle linker for TraceGraph",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build":     "tsup src/index.ts --format cjs,esm --dts --external '@tracegraph/*'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tracegraph/shared-types": "workspace:*",
    "@tracegraph/trace-core":   "workspace:*"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
