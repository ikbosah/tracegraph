{
  "name": "tracegraph-monorepo",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "tsc --noEmit -p tsconfig.json",
    "clean:artifacts": "pnpm -r --if-present clean"
  },
  "devDependencies": {
    "@tracegraph/vitest": "workspace:*",
    "@types/node": "^20.12.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
