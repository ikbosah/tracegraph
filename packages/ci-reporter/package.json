{
  "name": "@tracegraph/ci-reporter",
  "version": "0.1.0",
  "description": "Renders TraceGraph reports as markdown, JSON, or GitHub Step Summary",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build":     "tsup src/index.ts --format cjs,esm --dts --external '@tracegraph/*'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tracegraph/shared-types": "workspace:*"
  }
}
